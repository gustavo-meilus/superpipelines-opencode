#!/usr/bin/env bash
# SessionStart hook for superpipelines plugin.
# Loads the using-superpipelines skill body and injects it as session context.
# Output must be byte-identical across runs (cache stability requirement).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_superpipelines_content=$(cat "${PLUGIN_ROOT}/skills/using-superpipelines/SKILL.md" 2>&1 || echo "Error reading using-superpipelines skill")

# Single-pass JSON string escape (orders of magnitude faster than character loops).
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_superpipelines_escaped=$(escape_for_json "$using_superpipelines_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have superpipelines.\n\n**Below is the full content of your 'superpipelines:using-superpipelines' skill — your introduction to designing and running AI pipelines. For all other skills, use the 'Skill' tool:**\n\n${using_superpipelines_escaped}\n</EXTREMELY_IMPORTANT>"

# Emit Claude Code SessionStart payload.
# Uses printf instead of heredoc to avoid bash 5.3+ heredoc edge cases.
printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"

exit 0
