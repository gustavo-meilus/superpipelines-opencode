{
  "$schema": "https://json.schemastore.org/opencode-settings.json",
  "autoMemoryEnabled": false,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)"
    ]
  },
  "env": {
    "OPENCODE_DISABLE_AUTO_MEMORY": "1"
  }
}
