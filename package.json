{
  "name": "superpipelines-opencode",
  "version": "1.0.6",
  "description": "Multi-agent AI orchestration framework with guaranteed spec compliance, write/review isolation, and full crash recovery",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./tui": {
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "agents",
    "skills",
    "commands",
    "scripts",
    ".opencode",
    ".opencodeignore",
    "settings.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/tui.ts --format esm --clean",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gustavo-meilus/superpipelines-opencode.git"
  },
  "keywords": [
    "opencode",
    "plugin",
    "multi-agent",
    "orchestration",
    "ai",
    "pipeline",
    "spec-driven-development"
  ],
  "author": "Gustavo Meilus",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gustavo-meilus/superpipelines-opencode/issues"
  },
  "homepage": "https://github.com/gustavo-meilus/superpipelines-opencode#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "25.6.0",
    "tsup": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.14.39",
    "yaml": "^2.8.4"
  }
}
